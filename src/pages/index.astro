---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchBar from '../components/SearchBar.astro';
import { pages } from '../content/data/pages';
import { getCategoryIcon } from '../lib/utils';

const allPages = pages;
const categories = [
  { key: 'leave', label: 'ছুটি আবেদন', count: allPages.filter(p => p.subcategory === 'leave').length, icon: '📝', href: '/application/leave', description: 'অসুস্থতার ছুটি, সাধারণ ছুটি, জরুরি কাজ' },
  { key: 'complaint', label: 'অভিযোগ চিঠি', count: allPages.filter(p => p.subcategory === 'complaint').length, icon: '⚠️', href: '/letter/complaint', description: 'পানি, বিদ্যুৎ, শব্দ ও দূষণ' },
  { key: 'certificate', label: 'সার্টিফিকেট আবেদন', count: allPages.filter(p => p.subcategory === 'certificate').length, icon: '📜', href: '/application/certificate', description: 'বোনাফাইড, চরিত্র, আয় ও বসবাস' },
  { key: 'bank', label: 'ব্যাংক চিঠি', count: allPages.filter(p => p.subcategory === 'bank').length, icon: '🏦', href: '/application/bank', description: 'KYC, লোন, চেক বই ও অ্যাকাউন্ট' },
  { key: 'government', label: 'সরকারি আবেদন', count: allPages.filter(p => p.subcategory === 'government').length, icon: '🏛️', href: '/application/government', description: 'আধার, প্যান, ভোটার কার্ড ও রেশন' },
  { key: 'school', label: 'স্কুল আবেদন', count: allPages.filter(p => p.subcategory === 'school').length, icon: '🎓', href: '/application/school', description: 'স্কলারশিপ, ফি মওকুফ ও ট্রান্সফার' },
  { key: 'employment', label: 'চাকরির চিঠি', count: allPages.filter(p => p.subcategory === 'employment').length, icon: '💼', href: '/application/employment', description: 'পদত্যাগ, অভিজ্ঞতা ও অফার লেটার' },
];

const recentPages = allPages.slice(0, 8);

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "LetterFormat.in",
  "url": "https://letterformat.in",
  "description": "বিনামূল্যে ব্যবহারযোগ্য চিঠি ও আবেদন ফরম্যাট।",
  potentialAction: {
    "@type": "SearchAction",
    "target": "https://letterformat.in/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
});
---

<Layout
  title="LetterFormat.in — বিনামূল্যে চিঠি ও আবেদন ফরম্যাট"
  description="বিনামূল্যে ব্যবহারযোগ্য চিঠি ও আবেদন ফরম্যাট। ছাত্র, চাকরিজীবী ও সাধারণ মানুষের জন্য কপি-পেস্ট ফরম্যাট।"
  schemaMarkup={schemaMarkup}
>
  <Header />

  <main>
    <!-- Hero Section - White background with red accents per template -->
    <section class="hero">
      <div class="hero-bg-pattern"></div>
      <div class="container hero-content">
        <div class="hero-tag">
          <span class="tag-dot"></span>
          ভারতীয় ব্যবহারকারীদের জন্য বিনামূল্যে ফরম্যাট
        </div>
        <h1>বিনামূল্যে চিঠি ও <span class="highlight">আবেদন ফরম্যাট</span></h1>
        <p class="hero-desc">আপনার তথ্য পূরণ করুন এবং জমা দিন। কোনো সাইন-আপ নেই, কোনো ফি নেই — শুধু ব্যবহারযোগ্য পেশাদার ফরম্যাট।</p>
        
        <!-- Search Bar per template -->
        <div class="search-bar">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
          <input type="search" id="format-search" placeholder="ফরম্যাট খুঁজুন... (যেমন: জ্বরের ছুটি, অভিযোগ চিঠি)" />
          <button class="search-btn">খুঁজুন</button>
        </div>
        <div id="search-results" class="search-results"></div>
        
        <!-- Quick chips -->
        <div class="hero-chips">
          <span class="chip">জ্বরের ছুটি</span>
          <span class="chip">সার্টিফিকেট</span>
          <span class="chip">অভিযোগ</span>
          <span class="chip">পদত্যাগ</span>
        </div>
        
        <!-- Stats -->
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-num"><span>{allPages.length}+</span></span>
            <span class="stat-label">ফরম্যাট</span>
          </div>
          <div class="stat-item">
            <span class="stat-num"><span>৭</span></span>
            <span class="stat-label">বিভাগ</span>
          </div>
          <div class="stat-item">
            <span class="stat-num"><span>১০০%</span></span>
            <span class="stat-label">বিনামূল্যে</span>
          </div>
        </div>
      </div>
      
      <!-- Hero visual with document card - per template -->
      <div class="hero-visual">
        <div class="hero-doc-card">
          <div class="doc-header">
            <div class="doc-seal">📄</div>
            <div class="doc-meta">
              <div class="doc-title-sm">ছুটির আবেদন পত্র</div>
              <div class="doc-sub-sm">Application Letter</div>
            </div>
            <span class="doc-badge">✓ সঠিক ফরম্যাট</span>
          </div>
          <div class="doc-lines">
            <div class="doc-line w-full"></div>
            <div class="doc-line w-4-5"></div>
            <div class="doc-line w-3-5"></div>
            <div class="doc-line w-2-5"></div>
          </div>
          <div class="doc-sign">
            <div class="sign-block">
              <div class="sign-line"></div>
              <div class="sign-label">স্বাক্ষর</div>
            </div>
          </div>
        </div>
        
        <!-- Floating badges per template -->
        <div class="floating-badge top-left">
          <span class="badge-icon red">✓</span>
          <span>কপি-পেস্ট</span>
        </div>
        <div class="floating-badge bot-right">
          <span class="badge-icon green">📋</span>
          <span>বাংলায়</span>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="section categories-section">
      <div class="container">
        <div class="section-header">
          <h2>বিভাগ অনুযায়ী দেখুন</h2>
          <p>আপনার প্রয়োজনের জন্য সঠিক ফরম্যাট খুঁজুন</p>
        </div>
        
        <div class="category-grid stagger">
          {categories.map(cat => (
            <a href={cat.href} class="category-card">
              <div class="category-card-inner">
                <div class="category-icon">{cat.icon}</div>
                <div class="category-info">
                  <h3>{cat.label}</h3>
                  <p>{cat.description}</p>
                </div>
                <div class="category-count">
                  <span>{cat.count}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Popular Formats Section -->
    <section class="section formats-section">
      <div class="container">
        <div class="section-header">
          <h2>জনপ্রিয় ফরম্যাট</h2>
          <p>এই মাসে সবচেয়ে বেশি খোঁজা হওয়া ফরম্যাট</p>
        </div>
        
        <div class="format-grid stagger">
          {recentPages.map(page => (
            <a href={`/format/${page.slug}/`} class="format-card">
              <div class="format-card-icon">{getCategoryIcon(page.subcategory)}</div>
              <div class="format-card-info">
                <span class="format-card-title">{page.keyword}</span>
                <span class="format-card-meta">{page.category} · {page.subcategory}</span>
              </div>
              <svg class="format-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="section how-section section-alt">
      <div class="container">
        <div class="section-header centered">
          <h2>কিভাবে কাজ করে</h2>
          <p>৩ সহজ ধাপে আপনার চিঠি পান</p>
        </div>
        
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">০১</div>
            <div class="step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
              </svg>
            </div>
            <h3>খুঁজুন</h3>
            <p>সার্চ বার বা বিভাগ থেকে প্রয়োজনীয় ফরম্যাট খুঁজুন।</p>
          </div>
          
          <div class="step-card">
            <div class="step-number">০২</div>
            <div class="step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </div>
            <h3>কপি করুন</h3>
            <p>কপি বাটনে ক্লিক করে ফরম্যাট ক্লিপবোর্ডে কপি করুন।</p>
          </div>
          
          <div class="step-card">
            <div class="step-number">০৩</div>
            <div class="step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <h3>পূরণ করুন ও জমা দিন</h3>
            <p>ব্র্যাকেটের তথ্যগুলো আপনার তথ্য দিয়ে পূরণ করুন এবং জমা দিন।</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-card">
          <div class="cta-content">
            <h2>কাস্টম ফরম্যাট দরকার?</h2>
            <p>যা খুঁজছেন তা নেই? আমাদের জানান, আমরা যোগ করব।</p>
          </div>
          <a href="mailto:hello@letterformat.in" class="btn btn-primary">
            ফরম্যাট চান
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  // Search functionality
  const pages = [
    {"keyword":"অসুস্থতার ছুটির আবেদন","slug":"application-leave-due-to-fever","category":"application","subcategory":"leave"},
    {"keyword":"অসুস্থতার ছুটির আবেদন","slug":"application-sick-leave","category":"application","subcategory":"leave"},
    {"keyword":"সাধারণ ছুটির আবেদন","slug":"application-casual-leave","category":"application","subcategory":"leave"},
    {"keyword":"বোনের বিয়ের ছুটির আবেদন","slug":"application-sister-wedding-leave","category":"application","subcategory":"leave"},
    {"keyword":"পারিবারিক অনুষ্ঠানে ছুটি","slug":"application-family-function-leave","category":"application","subcategory":"leave"},
    {"keyword":"জরুরি কাজের জন্য ছুটি","slug":"application-urgent-piece-of-work","category":"application","subcategory":"leave"},
    {"keyword":"বাড়ি যাওয়ার ছুটি","slug":"application-going-home-leave","category":"application","subcategory":"leave"},
    {"keyword":"ডাক্তারের অ্যাপয়েন্টমেন্টে ছুটি","slug":"application-medical-appointment-leave","category":"application","subcategory":"leave"},
    {"keyword":"ডেন্টিস্টের অ্যাপয়েন্টমেন্টে ছুটি","slug":"application-dental-appointment-leave","category":"application","subcategory":"leave"},
    {"keyword":"পানি সংকটের অভিযোগ","slug":"complaint-letter-water-shortage","category":"letter","subcategory":"complaint"},
    {"keyword":"রাস্তার ক্ষতির অভিযোগ","slug":"complaint-letter-road-damage","category":"letter","subcategory":"complaint"},
    {"keyword":"শব্দ দূষণের অভিযোগ","slug":"complaint-letter-noise-pollution","category":"letter","subcategory":"complaint"},
    {"keyword":"আবর্জনা সংগ্রহের অভিযোগ","slug":"complaint-letter-garbage-collection","category":"letter","subcategory":"complaint"},
    {"keyword":"বিদ্যুৎ বিভাগের লোডশেডিং অভিযোগ","slug":"complaint-letter-electricity-board-power-cut","category":"letter","subcategory":"complaint"},
    {"keyword":"বোনাফাইড সার্টিফিকেটের আবেদন","slug":"application-bonafide-certificate","category":"application","subcategory":"certificate"},
    {"keyword":"চরিত্র সার্টিফিকেটের আবেদন","slug":"application-character-certificate","category":"application","subcategory":"certificate"},
    {"keyword":"আয় সার্টিফিকেটের আবেদন","slug":"application-income-certificate","category":"application","subcategory":"certificate"},
    {"keyword":"বসবাস সার্টিফিকেটের আবেদন","slug":"application-domicile-certificate","category":"application","subcategory":"certificate"},
    {"keyword":"ব্যাংক KYC আপডেটের আবেদন","slug":"application-bank-kyc-update","category":"application","subcategory":"bank"},
    {"keyword":"ব্যাংক লোনের আবেদন","slug":"application-bank-loan","category":"application","subcategory":"bank"},
    {"keyword":"চেক বইয়ের আবেদন","slug":"application-bank-cheque-book","category":"application","subcategory":"bank"},
    {"keyword":"ব্যাংক অ্যাকাউন্ট বন্ধের চিঠি","slug":"letter-bank-account-closure","category":"letter","subcategory":"bank"},
    {"keyword":"আধার আপডেটের আবেদন","slug":"application-aadhaar-update","category":"application","subcategory":"government"},
    {"keyword":"প্যান কার্ডের আবেদন","slug":"application-pan-card","category":"application","subcategory":"government"},
    {"keyword":"রেশন কার্ডের আবেদন","slug":"application-ration-card","category":"application","subcategory":"government"},
    {"keyword":"ভোটার কার্ড সংশোধনের আবেদন","slug":"application-voter-id-correction","category":"application","subcategory":"government"},
    {"keyword":"স্কুল স্কলারশিপের আবেদন","slug":"application-school-scholarship","category":"application","subcategory":"school"},
    {"keyword":"স্কুল ফি মওকুফের আবেদন","slug":"application-school-fee-concession","category":"application","subcategory":"school"},
    {"keyword":"চাকরির অভিজ্ঞতা পত্রের আবেদন","slug":"application-employment-experience-letter","category":"application","subcategory":"employment"},
    {"keyword":"পদত্যাগ পত্রের আবেদন","slug":"application-employment-resignation","category":"application","subcategory":"employment"}
  ];

  const input = document.getElementById('format-search');
  const resultsDiv = document.getElementById('search-results');

  if (input && resultsDiv) {
    input.addEventListener('input', function() {
      const query = this.value.toLowerCase().trim();
      if (query.length < 2) {
        resultsDiv.innerHTML = '';
        resultsDiv.style.display = 'none';
        return;
      }

      const filtered = pages.filter(function(p) {
        const searchText = (p.keyword + ' ' + p.category + ' ' + p.subcategory).toLowerCase();
        return query.split(' ').every(function(word) {
          return searchText.includes(word);
        });
      });

      if (filtered.length === 0) {
        resultsDiv.innerHTML = '<p class="no-results">কোনো ফরম্যাট পাওয়া যায়নি। অন্য কীওয়ার্ড চেষ্টা করুন।</p>';
        resultsDiv.style.display = 'block';
        return;
      }

      resultsDiv.innerHTML = filtered
        .slice(0, 10)
        .map(function(p) {
          return '<a href="/format/' + p.slug + '/" class="search-item">' + p.keyword + '</a>';
        })
        .join('');
      resultsDiv.style.display = 'block';
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('.hero-search')) {
        resultsDiv.innerHTML = '';
        resultsDiv.style.display = 'none';
      }
    });
  }
</script>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    background: var(--color-primary);
    padding: 5rem 0 6rem;
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 80%, rgba(220, 38, 38, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(220, 38, 38, 0.1) 0%, transparent 40%),
      linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  }
  
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 720px;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    animation: fadeInUp 0.6s ease forwards;
  }
  
  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .hero h1 {
    font-size: 3.5rem;
    color: white;
    margin-bottom: var(--space-md);
    animation: fadeInUp 0.6s ease 0.1s forwards;
    opacity: 0;
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    animation: fadeInUp 0.6s ease 0.2s forwards;
    opacity: 0;
  }
  
  .hero-search {
    position: relative;
    max-width: 560px;
    margin: 0 auto var(--space-xl);
    animation: fadeInUp 0.6s ease 0.3s forwards;
    opacity: 0;
  }
  
  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--color-text-muted);
    pointer-events: none;
  }
  
  .hero-search input {
    width: 100%;
    padding: 1.25rem 1.5rem 1.25rem 3.5rem;
    font-size: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.05);
    color: white;
    backdrop-filter: blur(10px);
    transition: all var(--transition-fast);
  }
  
  .hero-search input::placeholder {
    color: var(--color-text-muted);
  }
  
