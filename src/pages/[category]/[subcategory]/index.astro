---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { pages } from '../../../content/data/pages';
import { getCategoryLabel, getSubcategoryLabel, getCategoryIcon } from '../../../lib/utils';

export function getStaticPaths() {
  const subcategories = [...new Set(pages.map(p => `${p.category}|||${p.subcategory}`))];
  return subcategories.map(sc => {
    const [category, subcategory] = sc.split('|||');
    const subPages = pages.filter(p => p.category === category && p.subcategory === subcategory);
    return {
      params: { category, subcategory },
      props: { category, subcategory, pages: subPages },
    };
  });
}

const { category, subcategory, pages: subPages } = Astro.props;
const title = `${getSubcategoryLabel(subcategory)} — Free Formats & Templates [2026]`;
const description = `Browse ${subPages.length} free ${getSubcategoryLabel(subcategory).toLowerCase()} formats. Copy-paste ready, no sign-up needed.`;
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Page Header -->
    <div class="category-header">
      <div class="container">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: getCategoryLabel(category), href: `/${category}/${subcategory}` },
          { label: getSubcategoryLabel(subcategory) }
        ]} />
        
        <div class="category-header-content">
          <div class="category-icon">{getCategoryIcon(subcategory)}</div>
          <div class="category-header-text">
            <h1>{getSubcategoryLabel(subcategory)}</h1>
            <p>Browse {subPages.length} ready-to-use formats. Click any format to view, copy, and customize for your needs.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Formats Grid -->
    <div class="container page-content">
      <div class="formats-grid">
        {subPages.map(page => (
          <a href={`/format/${page.slug}/`} class="format-card">
            <div class="format-card-icon">{getCategoryIcon(page.subcategory)}</div>
            <div class="format-card-info">
              <span class="format-card-title">{page.keyword}</span>
              <span class="format-card-meta">For {page.userSegment === 'student' ? 'Students' : page.userSegment === 'employee' ? 'Employees' : 'General Public'}</span>
            </div>
            <svg class="format-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .category-header {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    padding: var(--space-xl) 0 var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }
  
  .category-header-content {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }
  
  .category-icon {
    font-size: 3.5rem;
    flex-shrink: 0;
  }
  
  .category-header-text {
    flex: 1;
  }
  
  .category-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-sm);
  }
  
  .category-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin: 0;
  }
  
  .page-content {
    padding: var(--space-2xl) var(--space-lg);
  }
  
  .formats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-md);
  }
  
  .format-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
  }
  
  .format-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  
  .format-card-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }
  
  .format-card-info {
    flex: 1;
    min-width: 0;
  }
  
  .format-card-title {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .format-card-meta {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }
  
  .format-card-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }
  
  .format-card:hover .format-card-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }
  
  @media (max-width: 768px) {
    .category-header-content {
      flex-direction: column;
      gap: var(--space-md);
    }
    
    .category-header h1 {
      font-size: 1.5rem;
    }
    
    .formats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
